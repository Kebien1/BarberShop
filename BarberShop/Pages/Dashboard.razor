@page "/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<div class="container-fluid mt-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Dashboard</h1>
                <button class="btn btn-danger" @onclick="LogoutAsync">Cerrar Sesión</button>
            </div>
        </div>
    </div>

    <AuthorizeView Context="authContext">
        <Authorized>
            <div class="row">
                <div class="col-md-4">
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">Información de Sesión</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Rol:</strong> <span class="badge bg-success">@authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</span></p>
                            <p><strong>ID Rol:</strong> @authContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value</p>
                            <p><strong>Descripción:</strong> @authContext.User.FindFirst("Description")?.Value</p>
                            <p><strong>Conectado desde:</strong> @authContext.User.FindFirst("LoginTime")?.Value</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">Panel de Control</h5>
                        </div>
                        <div class="card-body">
                            <AuthorizeView Roles="ADMIN" Context="adminContext">
                                <Authorized>
                                    <div class="alert alert-warning">
                                        <h6>Acceso Administrativo</h6>
                                        <p>Tienes acceso a todas las funciones del sistema.</p>
                                        <a href="/roles" class="btn btn-primary">Gestionar Roles</a>
                                    </div>
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="BARBERO" Context="barberoContext">
                                <Authorized>
                                    <div class="alert alert-info">
                                        <h6>Panel de Barbero</h6>
                                        <p>Acceso a funciones de citas y servicios de barbería.</p>
                                        <button class="btn btn-primary disabled">Citas (Próximamente)</button>
                                    </div>
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="VENDEDOR" Context="vendedorContext">
                                <Authorized>
                                    <div class="alert alert-success">
                                        <h6>Panel de Ventas</h6>
                                        <p>Acceso a funciones de ventas y productos.</p>
                                        <button class="btn btn-primary disabled">Ventas (Próximamente)</button>
                                    </div>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-danger">
                No estás autenticado. <a href="/login">Inicia sesión aquí</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private async Task LogoutAsync()
    {
        var authStateProvider = (Authentication.CustomAuthenticationStateProvider)AuthenticationStateProvider;
        await authStateProvider.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
