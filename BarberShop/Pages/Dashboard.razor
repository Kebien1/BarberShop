@page "/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            <div class="card shadow-lg border-0 rounded-3">

                <div class="card-header bg-dark text-white p-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h2 class="mb-1">💈 BarberShop Dashboard</h2>
                            <p class="mb-0 text-muted">Panel de control interno</p>
                        </div>

                        <AuthorizeView>
                            <Authorized>
                                <span class="badge bg-primary fs-6 px-3 py-2 mt-2 mt-sm-0">
                                    🔑 Conectado como: @context.User.Identity?.Name
                                </span>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>

                <div class="card-body p-4 p-sm-5">
                    <AuthorizeView>
                        <Authorized>

                            <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
                                <span class="fs-4 me-3">🎉</span>
                                <div>
                                    <strong>¡Acceso Autorizado!</strong> Has ingresado correctamente al sistema de la barbería.
                                </div>
                            </div>

                            <div>
                                <h4 class="text-secondary mb-3">📋 Información de tu Sesión</h4>
                                <div class="p-3 bg-light rounded-3 border">
                                    <div class="row g-2">
                                        <div class="col-sm-4 text-muted"><strong>Identificador / Rol:</strong></div>
                                        <div class="col-sm-8 text-dark">@context.User.Identity?.Name</div>

                                        <div class="col-sm-4 text-muted"><strong>Descripción del Perfil:</strong></div>
                                        <div class="col-sm-8 text-dark">@context.User.FindFirst("Description")?.Value</div>

                                        <div class="col-sm-4 text-muted"><strong>Fecha y Hora de Entrada:</strong></div>
                                        <div class="col-sm-8 text-dark text-monospace">@context.User.FindFirst("LoginTime")?.Value</div>
                                    </div>
                                </div>
                            </div>

                        </Authorized>

                        <NotAuthorized>
                            <div class="alert alert-danger" role="alert">
                                🔒 No tienes autorización para ver este contenido. Por favor, regresa al Login.
                            </div>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>

            </div>

        </div>
    </div>
</div>

@code {
    // Código simplificado sin lógica de botones temporales
}