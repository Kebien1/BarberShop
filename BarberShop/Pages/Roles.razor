@page "/roles"
@using BarberShop.Models
@using BarberShop.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IRoleService RoleService
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView Roles="ADMIN" Context="rolesContext">
    <Authorized>
        <div class="container-fluid mt-4">
            <div class="row">
                <div class="col-12">
                    <h1 class="mb-4">Gestión de Roles</h1>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    @if (showForm)
                    {
                        <div class="card mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">@(isEditing ? "Editar Rol" : "Crear Nuevo Rol")</h5>
                            </div>
                            <div class="card-body">
                                <form>
                                    <div class="mb-3">
                                        <label class="form-label">Nombre del Rol</label>
                                        <input type="text" class="form-control" @bind="currentRole.Name" placeholder="Ej: ADMIN">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Descripcion</label>
                                        <textarea class="form-control" @bind="currentRole.Description" rows="3" placeholder="Describa el rol..."></textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Contraseña</label>
                                        <div class="input-group">
                                            <input type="@(showPassword ? "text" : "password")" 
                                                   class="form-control" 
                                                   @bind="currentRole.Password" 
                                                   placeholder="Ingresa una contraseña segura">
                                            <button class="btn btn-outline-secondary" 
                                                    type="button" 
                                                    @onclick="TogglePasswordVisibility">
                                                <span class="@(showPassword ? "oi oi-eye" : "oi oi-eye-off")"></span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-success" @onclick="SaveRoleAsync">
                                            @(isEditing ? "Actualizar" : "Crear")
                                        </button>
                                        <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancelar</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-primary mb-4" @onclick="ShowCreateForm">
                            Crear Nuevo Rol
                        </button>
                    }
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    @if (roles == null)
                    {
                        <div class="alert alert-info">Cargando roles...</div>
                    }
                    else if (roles.Count == 0)
                    {
                        <div class="alert alert-warning">No hay roles registrados.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th>Descripcion</th>
                                        <th>Contraseña</th>
                                        <th>Fecha de Creacion</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in roles)
                                    {
                                        <tr>
                                            <td>@role.Id</td>
                                            <td><span class="badge bg-info">@role.Name</span></td>
                                            <td>@role.Description</td>
                                            <td>
                                                <span class="text-muted">
                                                    @if (showPasswords.Contains(role.Id))
                                                    {
                                                        <span>@role.Password</span>
                                                        <button class="btn btn-sm btn-link" @onclick="() => TogglePasswordDisplay(role.Id)">
                                                            <span class="oi oi-eye-off"></span>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span>•••••••</span>
                                                        <button class="btn btn-sm btn-link" @onclick="() => TogglePasswordDisplay(role.Id)">
                                                            <span class="oi oi-eye"></span>
                                                        </button>
                                                    }
                                                </span>
                                            </td>
                                            <td>@role.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <button class="btn btn-sm btn-warning me-2" @onclick="() => EditRoleAsync(role)">
                                                    Editar
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteRoleAsync(role.Id)">
                                                    Eliminar
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-5">
            <h4>Acceso Denegado</h4>
            <p>Solo los administradores pueden gestionar roles.</p>
            <a href="/" class="btn btn-primary">Volver al Inicio</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Role>? roles;
    private Role currentRole = new();
    private bool showForm = false;
    private bool isEditing = false;
    private bool showPassword = false;
    private HashSet<int> showPasswords = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRolesAsync();
    }

    private async Task LoadRolesAsync()
    {
        roles = await RoleService.GetAllRolesAsync();
    }

    private void ShowCreateForm()
    {
        currentRole = new Role();
        isEditing = false;
        showForm = true;
    }

    private async Task EditRoleAsync(Role role)
    {
        currentRole = new Role 
        { 
            Id = role.Id, 
            Name = role.Name, 
            Description = role.Description,
            Password = role.Password,
            CreatedAt = role.CreatedAt
        };
        isEditing = true;
        showForm = true;
    }

    private async Task SaveRoleAsync()
    {
        if (string.IsNullOrWhiteSpace(currentRole.Name))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(currentRole.Password))
        {
            return;
        }

        if (isEditing)
        {
            await RoleService.UpdateRoleAsync(currentRole);
        }
        else
        {
            await RoleService.CreateRoleAsync(currentRole);
        }

        await LoadRolesAsync();
        CancelForm();
    }

    private async Task DeleteRoleAsync(int id)
    {
        if (await RoleService.DeleteRoleAsync(id))
        {
            await LoadRolesAsync();
        }
    }

    private void CancelForm()
    {
        showForm = false;
        currentRole = new Role();
        isEditing = false;
        showPassword = false;
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void TogglePasswordDisplay(int roleId)
    {
        if (showPasswords.Contains(roleId))
        {
            showPasswords.Remove(roleId);
        }
        else
        {
            showPasswords.Add(roleId);
        }
    }
}
